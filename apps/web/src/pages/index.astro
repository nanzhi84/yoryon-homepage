---
import { getCollection } from "astro:content";
import SiteShell from "../layouts/SiteShell.astro";

const getEntrySlug = (entry) => entry.slug ?? entry.id.replace(/\.(mdoc|mdx?)$/, "");
const formatDate = (date) => new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
}).format(date);

const recentPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);
---

<SiteShell
  title="Yoryon | Personal Homepage"
  description="Yoryon 的个人主页，记录产品、思考、成长与项目实践。"
  activeNav="home"
>
  <main class="home-main">
    <section class="hero" id="home" aria-label="首页介绍">
      <div class="hero-media" aria-hidden="true">
        <picture>
          <source srcset="/assets/home-workspace-minimal.webp" type="image/webp" />
          <img
            src="/assets/home-workspace-minimal.png"
            alt=""
            width="1536"
            height="1024"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      </div>
      <div class="container hero-inner">
        <div class="hero-copy reveal">
        <h1>Yoryon</h1>
          <p class="hero-desc">关注产品思考、写作与成长，在创造与复盘中持续迭代自己。</p>
          <div class="hero-index" aria-label="主页入口">
            <a href="#thinking"><span>01</span><strong>Thinking / 写作</strong><em>→</em></a>
            <a href="#projects"><span>02</span><strong>Projects / 项目</strong><em>→</em></a>
          </div>
          <p class="hero-contact">
            <a href="#contact">Contact →</a>
            <span>或发送邮件至</span>
            <a href="mailto:zhouyangyang@bupt.edu.cn">zhouyangyang@bupt.edu.cn</a>
          </p>
        </div>
      </div>
    </section>

    <section class="about container section" id="about">
      <div class="section-aside reveal">
        <h2>About</h2>
        <p>关于我</p>
      </div>
      <div class="about-content reveal reveal-delay">
        <p>我叫 Yoryon，目前在北京邮电大学读本科，专业是信息与计算科学。</p>
        <p>关注 AI 产品方向，喜欢把 LLM 应用、Agent 工作流和模型评测这些事拆解清楚再落地成产品，并通过写作沉淀认知、记录成长。</p>
        <p>正在做的事：从用户场景、机制设计到工程协作，把 AI 能力跑成真实可用的产品。</p>
        <dl class="fact-list">
          <div><dt>身份</dt><dd>北京邮电大学 在读 · 信息与计算科学</dd></div>
          <div><dt>方向</dt><dd>AI 产品 · LLM 应用 · Agent 工作流 · 模型评测</dd></div>
          <div><dt>方式</dt><dd>观察 · 思考 · 实践 · 复盘</dd></div>
          <div><dt>工具</dt><dd>Python、TypeScript、Next.js、NestJS、PostgreSQL、PyTorch</dd></div>
          <div><dt>邮箱</dt><dd><a href="mailto:zhouyangyang@bupt.edu.cn">zhouyangyang@bupt.edu.cn</a></dd></div>
        </dl>
      </div>
    </section>

    <section class="container section home-thinking" id="thinking">
      <div class="section-heading reveal">
        <div>
          <h2>Latest Thinking</h2>
          <p>最近的思考与写作</p>
        </div>
        <a href="/blog/" class="text-link">查看全部文章 →</a>
      </div>

      <div class="article-list">
        {recentPosts.map((post, index) => (
          <a class:list={["article-row", "reveal", { "reveal-delay-2": index === 1, "reveal-delay-3": index === 2 }]} href={`/blog/${getEntrySlug(post)}/`}>
            <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            <article>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
            </article>
            <span aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>

    <section class="container section" id="projects">
      <div class="section-heading reveal">
        <div>
          <h2>Selected Projects</h2>
          <p>精选项目</p>
        </div>
        <a href="#projects" class="text-link">查看全部项目 →</a>
      </div>
      <div class="project-list">
        {projects.map((project, index) => (
          <a class:list={["project-row", "reveal", { "reveal-delay-2": index === 1, "reveal-delay-3": index === 2 }]} href={`/projects/${getEntrySlug(project)}/`}>
            <span class="project-number">{String(index + 1).padStart(2, "0")}</span>
            <article>
              <h3>{project.data.title}</h3>
              <p>{project.data.summary}</p>
            </article>
            <span class="project-stack">{project.data.stack}</span>
            <span class="project-action">项目详情 →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="container section footer-panel" id="contact">
      <div class="section-aside reveal">
        <h2>Contact</h2>
        <p>联系我</p>
      </div>
      <div class="contact-content reveal reveal-delay">
        <p>有想法、合作或交流，欢迎通过下面任一方式联系我。</p>
        <dl class="fact-list contact-list">
          <div>
            <dt>Email</dt>
            <dd><a href="mailto:zhouyangyang@bupt.edu.cn">zhouyangyang@bupt.edu.cn</a></dd>
          </div>
          <div>
            <dt>GitHub</dt>
            <dd><a href="https://github.com/nanzhi84" target="_blank" rel="noopener noreferrer">github.com/nanzhi84</a></dd>
          </div>
        </dl>
      </div>
    </section>
  </main>
</SiteShell>
